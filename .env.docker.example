POSTGRES_DB=love_next
POSTGRES_USER=love_next
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine
APP_IMAGE=ghcr.nju.edu.cn/lanmoyan/loveblog:latest
APP_PULL_POLICY=missing
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
NEXTAUTH_SECRET="replace-with-the-same-long-random-secret"
NEXTAUTH_URL="https://your-domain.example"
RUN_MIGRATIONS=1
APP_CPUS=1.0
APP_MEMORY=768m
NODE_OPTIONS=--max-old-space-size=384
STORAGE_DRIVER=local
UPLOAD_DIR=/app/uploads
S3_ENDPOINT=""
S3_REGION=auto
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""
S3_KEY_PREFIX=uploads
S3_FORCE_PATH_STYLE=0
SMTP_HOST=""
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
OAUTH_GITHUB_ID=""
OAUTH_GITHUB_SECRET=""
OAUTH_GOOGLE_ID=""
OAUTH_GOOGLE_SECRET=""
OAUTH_DISCORD_ID=""
OAUTH_DISCORD_SECRET=""
