{
  "name": "love-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build && node scripts/clean-generated.mjs",
    "build:next": "next build --webpack",
    "start": "node .next/standalone/server.js",
    "typecheck": "tsc --noEmit --incremental false",
    "db:prepare": "node scripts/prepare-db.mjs",
    "db:push": "prisma db push",
    "db:migrate": "npm run db:prepare && prisma migrate deploy",
    "db:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "clean:generated": "node scripts/clean-generated.mjs",
    "clean:next": "node scripts/clean-generated.mjs --next",
    "import:old": "node --experimental-sqlite --disable-warning=ExperimentalWarning scripts/import-old-db.mjs --reset"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.80.6",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "minisearch": "^7.2.0",
    "next": "16.2.7",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.57.0",
    "sharp": "^0.35.1",
    "yet-another-react-lightbox": "^3.32.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "next": {
      "postcss": "8.5.10"
    }
  }
}
